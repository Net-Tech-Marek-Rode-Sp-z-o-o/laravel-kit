{
    "preset": "laravel",
    "rules": {
        "method_argument_space": {
            "on_multiline": "ensure_fully_multiline"
        },
        "nullable_type_declaration": {
            "syntax": "union"
        },
        "nullable_type_declaration_for_default_null_value": false,
        "phpdoc_align": {
            "align": "left"
        }
    }
}
